{
  "name": "corp-web-micro",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for small QueryPie micro websites.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @querypie/microsite-finance",
    "lint": "npm run lint --workspace @querypie/microsite-finance",
    "typecheck": "npm run typecheck --workspace @querypie/microsite-finance",
    "test": "node tests/repo-structure.test.mjs",
    "test:ci": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}
